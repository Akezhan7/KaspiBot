# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# ВАЖНО: впиши свой Telegram User ID (узнать: @userinfobot в Telegram)
ADMIN_USER_IDS=YOUR_TELEGRAM_USER_ID

# Proxy Settings
# Формат: http://login:password@host:port или socks5://login:password@host:port
# HTTP прокси (iproxy.online - мобильный прокси через Android)
PROXY_URL=http://login:password@host:port
PROXY_CHANGE_API=https://your-proxy-provider.com/changeip/YOUR_KEY

# Scanner Settings (ускорено для тестов, в production вернуть 12)
SCAN_INTERVAL_HOURS=12
BATCH_SIZE=50


# Rate Limits (секунды)
PRODUCT_DELAY_MIN=2
PRODUCT_DELAY_MAX=5
MERCHANT_DELAY_MIN=3
MERCHANT_DELAY_MAX=6
IP_CHANGE_DELAY_MIN=30
IP_CHANGE_DELAY_MAX=60

# Database
DB_PATH=data/kaspi_monitor.db

# === GREEN API (WhatsApp) ===
# Получить на https://green-api.com → Личный кабинет → Инстанс
GREEN_API_URL=https://YOUR_INSTANCE_ID.api.greenapi.com
GREEN_API_MEDIA_URL=https://YOUR_INSTANCE_ID.media.greenapi.com
GREEN_API_INSTANCE_ID=YOUR_INSTANCE_ID
GREEN_API_TOKEN=YOUR_GREEN_API_TOKEN

# Webhook для приёма входящих сообщений
WHATSAPP_WEBHOOK_HOST=0.0.0.0
WHATSAPP_WEBHOOK_PORT=8443
# Список разрешённых IP через запятую (пустое = все IP разрешены)
WHATSAPP_WEBHOOK_IP_WHITELIST=

# === OPENAI (LLM-классификация ответов продавцов) ===
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
LLM_CLASSIFICATION_TIMEOUT=5.0

# === Планировщик эскалации (ускорено для тестов) ===
# В production вернуть: ESCALATION=30, WARN1/WARN2=24, DIALOG=24, CHECK=1
ESCALATION_INTERVAL_MINUTES=1
WARN1_TIMEOUT_HOURS=0.03
WARN2_TIMEOUT_HOURS=0.03
DIALOG_TIMEOUT_HOURS=0.05
DIALOG_TIMEOUT_CHECK_HOURS=0.02
DAILY_MESSAGE_LIMIT=10

# === KASPI PAY (Scraper / Marketing) ===
# Вариант 1 (предпочтительный): логин/пароль
KASPI_PAY_LOGIN=
KASPI_PAY_PASSWORD=
# Вариант 2 (fallback): телефон + SMS
KASPI_PAY_PHONE=
KASPI_PAY_URL=https://kaspi.kz/mc
KASPI_MARKETING_ADS_URL=https://marketing.kaspi.kz/external/advertising/products/campaigns?tab=overview&activeTab=Enabled
KASPI_BONUSES_REVIEWS_URL=https://marketing.kaspi.kz/bonuses/reviews/promotions/list?state=Enabled
KASPI_BONUSES_PRODUCTS_URL=https://marketing.kaspi.kz/bonuses/products/promotions/list?state=Enabled
# Опционально: отдельный прокси для Kaspi Pay.
# Если не задан — берется PROXY_URL. Если задан пустым — прокси для Kaspi Pay отключен.
KASPI_PAY_PROXY_URL=
PLAYWRIGHT_HEADLESS=true
KASPI_PAY_NAV_TIMEOUT_SECONDS=60
SCRAPE_SCHEDULE_HOUR=3
SCRAPE_SCHEDULE_MINUTE=0
SCRAPE_ACTION_DELAY_MIN=1.0
SCRAPE_ACTION_DELAY_MAX=3.0
SMS_CODE_TIMEOUT_SECONDS=300
KASPI_MARKETING_REPORT_DAYS=7
# Список периодов отчётов через запятую: скрапер скачает XLSX для каждого
# (двойная выгрузка). Дефолт "7,30". Можно ужать до "7" если не нужны 30-дневные данные.
KASPI_MARKETING_REPORT_PERIODS=7,30

# === TMA API (Telegram Mini App) ===
TMA_API_HOST=0.0.0.0
TMA_API_PORT=8080
TMA_CORS_ORIGINS=https://web.telegram.org,https://t.me
TMA_URL=
