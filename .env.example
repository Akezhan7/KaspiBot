# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_IDS=123456789,987654321

# Proxy Settings
# Формат: http://login:password@host:port или socks5://login:password@host:port
PROXY_URL=http://login:password@host:port
PROXY_CHANGE_API=https://changeip.mobileproxy.space/?proxy_key=YOUR_PROXY_KEY

# Scanner Settings
SCAN_INTERVAL_HOURS=6
BATCH_SIZE=50

# Rate Limits (секунды)
PRODUCT_DELAY_MIN=2
PRODUCT_DELAY_MAX=5
MERCHANT_DELAY_MIN=3
MERCHANT_DELAY_MAX=6
IP_CHANGE_DELAY_MIN=30
IP_CHANGE_DELAY_MAX=60

# Database
DB_PATH=data/kaspi_monitor.db

# === GREEN API (WhatsApp) ===
# Получить на https://green-api.com → Личный кабинет → Инстанс
GREEN_API_URL=https://api.green-api.com
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_api_token

# Webhook для приёма входящих сообщений
WHATSAPP_WEBHOOK_HOST=0.0.0.0
WHATSAPP_WEBHOOK_PORT=8443
# Список разрешённых IP через запятую (пустое = все IP разрешены)
WHATSAPP_WEBHOOK_IP_WHITELIST=

# === OPENAI (LLM-классификация ответов продавцов) ===
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
LLM_CLASSIFICATION_TIMEOUT=5.0

# === Планировщик эскалации ===
ESCALATION_INTERVAL_MINUTES=30
WARN1_TIMEOUT_HOURS=24
WARN2_TIMEOUT_HOURS=24
DIALOG_TIMEOUT_HOURS=24
DIALOG_TIMEOUT_CHECK_HOURS=1
DAILY_MESSAGE_LIMIT=10
